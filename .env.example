# -------------------------------------------------------
# Discord GEO bot — environment variables
# Copy to .env and fill in your values.
# NEVER commit .env to source control.
# -------------------------------------------------------

# -------------------------------------------------------
# Discord bot
# Create at https://discord.com/developers/applications
#   Bot → Token
#   OAuth2 → URL Generator:
#     scopes: bot, applications.commands
#     permissions: Send Messages, Embed Links, Manage Messages, Read Message History
# -------------------------------------------------------
DISCORD_BOT_TOKEN=your_bot_token_here

# -------------------------------------------------------
# Discord alerts channel — webhook used by the background monitor
# Server Settings → Integrations → Webhooks → New Webhook
# Buttons on alert messages are handled by the bot itself (must be in the
# same server as the webhook), so interactions route back correctly.
# -------------------------------------------------------
DISCORD_ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# -------------------------------------------------------
# EC2 redirect checker endpoint
# Flask API on a t2.micro in eu-central-1 that spins up a
# NordVPN OpenVPN tunnel for the requested GEO and follows
# the chancer.bet redirect chain from inside the tunnel.
# -------------------------------------------------------
REDIRECT_CHECKER_URL=http://YOUR_EC2_PUBLIC_IP:8080
REDIRECT_CHECKER_KEY=a_shared_secret_key

# -------------------------------------------------------
# NordVPN service credentials (only used by ec2_setup.sh)
# Generate at: https://my.nordaccount.com/dashboard/nordvpn/manual-configuration/service-credentials/
# -------------------------------------------------------
NORDVPN_SERVICE_USER=your_nordvpn_service_username_here
NORDVPN_SERVICE_PASS=your_nordvpn_service_password_here

# -------------------------------------------------------
# Decodo (formerly Smartproxy) residential proxy
# Used by the monitor to health-check mirrors from real ISP IPs.
# gate.decodo.com:10001 — country targeted via username suffix:
#   user-{PROXY_USERNAME}-country-{cc}
# -------------------------------------------------------
PROXY_HOST=gate.decodo.com
PROXY_PORT=10001
PROXY_USERNAME=your_decodo_username_here
PROXY_PASSWORD=your_decodo_password_here

# -------------------------------------------------------
# RIPE Atlas API key — used by the monitor for DNS-based
# checks (Poland, future phase). Generate at:
# https://atlas.ripe.net/keys/
# -------------------------------------------------------
RIPE_ATLAS_API_KEY=your_ripe_atlas_api_key_here
